# ============================================
# 塘口镇 AR 文化平台 - 环境配置文件
# ============================================
# 复制本文件为 .env 并修改配置
#   cp .env.example .env
# ============================================

# 服务端口
PORT=3000

# JWT 密钥（请务必修改为随机字符串！）
# 生成随机密钥：https://www.random.org/strings/
JWT_SECRET=change-this-to-a-random-string

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tangkou2024

# 公网访问地址（部署到服务器后修改为实际域名或IP）
# 本地调试：http://localhost:3000
# 局域网：  http://192.168.x.x:3000
# 云服务器：http://你的服务器IP:3000 或 https://你的域名
BASE_URL=http://localhost:3000
