# Docker 构建时排除的文件
# 这些文件只在运行时需要，不应打入镜像

# 环境变量（含密码等敏感信息，运行时通过 --env-file 注入）
.env

# 依赖（构建时通过 npm ci 重新安装）
node_modules/

# 数据库和上传文件（运行时通过 volume 挂载）
data/database.sqlite
data/uploads/

# Git
.git/
.gitignore

# 文档和工具
docs/
*.md
cloudflared.exe

# 开发文件
.env.example
render.yaml

# 日志
*.log
npm-debug.log*
